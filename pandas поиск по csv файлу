import pandas
df = pandas.read_csv("Patients.csv")
print(df.columns)

dicto = {1: "name", 2: "age", 3: "etnicity", 4: "sex"}
while True:
        x = input("search by name - 1, by age - 2, by etnicity - 3, by sex - 4: ")
        try:
            x = int(x)
        except ValueError:
            print("only numbers are allowed")
            continue
        if x in range(1,5):
            print(df[dicto[x]])
        else:
            print("only given options are allowed")
            continue
        while True:
            dostupno = df[dicto[x]].unique()
            print(f"доступные значения: {dostupno}")
            y = input(f"more detailed search by {dicto[x]}: ")
            if dicto[x] == "age":
                try:
                    y = int(y)
                    print(y)
                except ValueError:
                    print("Only numbers are allowed here")
            else:
                y = y.capitalize()
                print(y)
            if y in df[dicto[x]].values:
                poisk = df[df[dicto[x]] == y]
                print(poisk)
                break
            else:
                print("data not found")
                continue
